# FastAPI Configuration
PROJECT_NAME="AI Meeting Translator"
DEBUG=true

# Database Configuration (Supabase / PostgreSQL)
# For local development: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL="postgresql://<username>:<password>@<host>:<port>/<dbname>"
SUPABASE_URL="https://<your-supabase-project-id>.supabase.co"
SUPABASE_KEY="your-supabase-anon-or-service-role-key"

# Active Providers Selection
# Options for STORAGE_PROVIDER: r2, local
STORAGE_PROVIDER="r2"
# Options for TRANSLATION_PROVIDER: deepl, google, llm
TRANSLATION_PROVIDER="deepl"
# Options for STT_PROVIDER: faster_whisper, whisper_live
STT_PROVIDER="faster_whisper"
# Options for SUMMARY_PROVIDER: openrouter, openai, gemini
SUMMARY_PROVIDER="openrouter"

# Cloudflare R2 / S3-compatible Object Storage Settings
R2_BUCKET_NAME="meeting-audio-chunks"
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_ENDPOINT_URL="https://<your-account-id>.r2.cloudflarestorage.com"

# DeepL Translation API Settings
DEEPL_API_KEY="your-deepl-api-key"

# OpenRouter / LLM Summary Settings
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="deepseek/deepseek-chat"

# Serverless GPU Worker (Modal.com) Settings
MODAL_WORKER_URL="https://<your-modal-username>--whisperx-app-process-audio.modal.run"
HF_TOKEN="your-huggingface-token-for-pyannote"
